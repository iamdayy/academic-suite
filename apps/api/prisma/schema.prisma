// File: apps/api/prisma/schema.prisma

// 1. Konfigurasi Generator Klien Prisma
// Ini memberi tahu Prisma untuk menghasilkan Klien TypeScript
generator client {
  provider = "prisma-client-js"
}

// 2. Konfigurasi Sumber Data
// Ini menghubungkan Prisma ke database PostgreSQL Anda melalui variabel .env
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")
}

// ===========================================
// BLOK 1: MANAJEMEN PENGGUNA & PERAN
// ===========================================

model Role {
  id        BigInt   @id @default(autoincrement())
  roleName  String   @unique @map("role_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Satu Role dimiliki banyak User
  users User[]

  @@map("roles")
}

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String
  roleId    BigInt   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi 1-to-1: User ini BISA jadi Student, Lecturer, atau Guardian
  student  Student?
  lecturer Lecturer?
  guardian        Guardian?
  facilityBookings FacilityBooking[]

  @@map("users")
}

model Student {
  id             BigInt       @id @default(autoincrement())
  userId         BigInt?      @unique @map("user_id") // Relasi 1-to-1
  user           User?        @relation(fields: [userId], references: [id])
  studyProgramId BigInt       @map("study_program_id")
  studyProgram   StudyProgram @relation(fields: [studyProgramId], references: [id])
  nim            String       @unique
  name           String
  status         String       @default("ACTIVE") // "ACTIVE", "ON_LEAVE", "GRADUATED", "DROPOUT"
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relasi: Student ini ada di...
  guardians         GuardianStudent[] // ...daftar wali
  krsHeaders        KrsHeader[] // ...daftar KRS
  classStudents     ClassStudent[] // ...daftar kelas yang diikuti
  submissions       AssignmentSubmission[] // ...daftar tugas yang dikumpulkan
  attendanceRecords AttendanceRecord[]
  studentScores     StudentScore[]
  invoices          Invoice[]
  thesis            Thesis?
  leaveRequests     LeaveRequest[]
  edomSubmissions   EdomSubmission[]
  yudisium          YudisiumRegistration?
  wisuda            WisudaRegistration?
  tracerStudy       TracerStudy?
  bookBorrowings    BookBorrowing[]

  @@map("students")
}

model Lecturer {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt?  @unique @map("user_id") // Relasi 1-to-1
  user      User?    @relation(fields: [userId], references: [id])
  nidn      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Dosen ini mengajar...
  classes Class[]
  thesisSupervisors ThesisSupervisor[]
  counselingLogs    CounselingLog[]
  thesisExaminers   ThesisExaminer[]

  @@map("lecturers")
}

model Guardian {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @unique @map("user_id") // Relasi 1-to-1
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Wali ini mewali...
  students GuardianStudent[]

  @@map("guardians")
}

// Tabel Pivot (Many-to-Many) antara Guardian dan Student
model GuardianStudent {
  id         BigInt   @id @default(autoincrement())
  guardianId BigInt   @map("guardian_id")
  guardian   Guardian @relation(fields: [guardianId], references: [id])
  studentId  BigInt   @map("student_id")
  student    Student  @relation(fields: [studentId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("guardian_student")
}

// ===========================================
// BLOK 2: STRUKTUR AKADEMIK & ADMINISTRASI
// ===========================================

model Major {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Satu Jurusan punya banyak Prodi
  studyPrograms StudyProgram[]

  @@map("majors")
}

model StudyProgram {
  id        BigInt   @id @default(autoincrement())
  majorId   BigInt   @map("major_id")
  major     Major    @relation(fields: [majorId], references: [id])
  name      String
  level     String // "S1", "D3", dll.
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Satu Prodi punya banyak...
  students    Student[]
  curriculums Curriculum[]

  @@map("study_programs")
}

model Curriculum {
  id             BigInt       @id @default(autoincrement())
  studyProgramId BigInt       @map("study_program_id")
  studyProgram   StudyProgram @relation(fields: [studyProgramId], references: [id])
  name           String // "Kurikulum 2020", "Kurikulum Merdeka"
  year           Int
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relasi: Satu Kurikulum punya banyak Mata Kuliah
  courses Course[]

  @@map("curriculums")
}

model Course {
  id           BigInt     @id @default(autoincrement())
  curriculumId BigInt     @map("curriculum_id")
  curriculum   Curriculum @relation(fields: [curriculumId], references: [id])
  code         String     @unique // "IF101"
  name         String // "Dasar Pemrograman"
  credits      Int // SKS
  semester     Int
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Relasi: Mata kuliah ini...
  prerequisites   Prerequisite[] @relation("coursePrerequisites") // ...memiliki prasyarat
  prerequisiteFor Prerequisite[] @relation("prerequisiteForCourse") // ...menjadi prasyarat
  classes         Class[] // ...memiliki banyak kelas

  @@map("courses")
}

// Model baru untuk Bobot Penilaian (dibuat oleh Dosen)
model GradingPolicy {
  id      BigInt @id @default(autoincrement())
  classId BigInt @unique @map("class_id") // Hanya 1 policy per Kelas
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Persentase Bobot (contoh: 10, 20, 30, 40)
  attendanceWeight Int @default(0) @map("attendance_weight")
  assignmentWeight Int @default(0) @map("assignment_weight")
  utsWeight        Int @default(0) @map("uts_weight")
  uasWeight        Int @default(0) @map("uas_weight")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("grading_policies")
}

// Model baru untuk menyimpan skor manual (UTS/UAS)
model StudentScore {
  id        BigInt  @id @default(autoincrement())
  studentId BigInt  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   BigInt  @map("class_id")
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Nilai 0-100 yang di-input Dosen
  scoreUTS Float? @map("score_uts")
  scoreUAS Float? @map("score_uas")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([studentId, classId]) // Mahasiswa hanya punya 1 set nilai per kelas
  @@map("student_scores")
}

// Tabel Prasyarat (Many-to-Many ke dirinya sendiri)
model Prerequisite {
  id                   BigInt   @id @default(autoincrement())
  courseId             BigInt   @map("course_id") // Mata kuliah yang punya prasyarat
  course               Course   @relation("coursePrerequisites", fields: [courseId], references: [id])
  prerequisiteCourseId BigInt   @map("prerequisite_course_id") // Mata kuliah yang JADI prasyarat
  prerequisiteCourse   Course   @relation("prerequisiteForCourse", fields: [prerequisiteCourseId], references: [id])
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("prerequisites")
}

model AcademicYear {
  id        BigInt   @id @default(autoincrement())
  year      String // "2024/2025"
  semester  String // "GANJIL", "GENAP"
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relasi: Tahun Ajaran ini punya...
  krsHeaders    KrsHeader[]
  classes       Class[]
  invoices      Invoice[]
  leaveRequests LeaveRequest[]

  @@map("academic_years")
}

// Master KRS (Header)
model KrsHeader {
  id             BigInt       @id @default(autoincrement())
  studentId      BigInt       @map("student_id")
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId BigInt       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  semester       Int // Semester ke- (1, 2, 3...)
  status         String // "DRAFT", "APPROVED", "REJECTED"
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relasi: KRS ini punya banyak...
  krsDetails KrsDetail[]

  @@map("krs_headers")
}

// Detail Mata Kuliah yang diambil di KRS
model KrsDetail {
  id          BigInt    @id @default(autoincrement())
  krsHeaderId BigInt    @map("krs_header_id")
  krsHeader   KrsHeader @relation(fields: [krsHeaderId], references: [id])
  classId     BigInt    @map("class_id")
  class       Class     @relation(fields: [classId], references: [id])
  grade       String? // Nilai akhir (A, B, C...) bisa null
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("krs_details")
}

// ===========================================
// BLOK 3: SESI PERKULIAHAN (PELAKSANAAN)
// ===========================================

// Ini adalah "pelaksanaan" dari sebuah Course di semester tertentu
model Class {
  id             BigInt       @id @default(autoincrement())
  courseId       BigInt       @map("course_id")
  course         Course       @relation(fields: [courseId], references: [id])
  lecturerId     BigInt       @map("lecturer_id")
  lecturer       Lecturer     @relation(fields: [lecturerId], references: [id])
  academicYearId BigInt       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  name           String // "Kelas A", "Kelas B"
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relasi: Kelas ini punya...
  students        ClassStudent[] // ...daftar mahasiswa
  materials       Material[] // ...daftar materi
  assignments     Assignment[] // ...daftar tugas
  krsDetails      KrsDetail[]
  classSchedules  ClassSchedule[]
  studentScores   StudentScore[]
  gradingPolicies GradingPolicy[]
  edomSubmissions EdomSubmission[]

  @@map("classes")
}

// Tabel jadwal mata kuliah
model ClassSchedule {
  id      BigInt @id @default(autoincrement())
  classId BigInt @map("class_id")
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  dayOfWeek String // Misal: "SENIN", "SELASA"
  startTime String // Misal: "08:00" (kita simpan sebagai string agar mudah)
  endTime   String // Misal: "10:30"
  facilityId BigInt? @map("facility_id")
  facility  Facility? @relation(fields: [facilityId], references: [id])

  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  attendanceSessions AttendanceSession[]

  @@map("class_schedules")
}

// Tabel Pivot (Many-to-Many) antara Class dan Student
// Ini adalah "Roster" atau "Daftar Peserta Kelas"
model ClassStudent {
  id        BigInt   @id @default(autoincrement())
  classId   BigInt   @map("class_id")
  class     Class    @relation(fields: [classId], references: [id])
  studentId BigInt   @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([classId, studentId]) // Mahasiswa hanya bisa join 1 kelas 1x
  @@map("class_student")
}

model Material {
  id        BigInt   @id @default(autoincrement())
  classId   BigInt   @map("class_id")
  class     Class    @relation(fields: [classId], references: [id])
  title     String
  fileUrl   String?  @map("file_url")
  content   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("materials")
}

model Assignment {
  id          BigInt   @id @default(autoincrement())
  classId     BigInt   @map("class_id")
  class       Class    @relation(fields: [classId], references: [id])
  title       String
  description String   @db.Text
  deadline    DateTime
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relasi: Tugas ini punya banyak...
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           BigInt     @id @default(autoincrement())
  assignmentId BigInt     @map("assignment_id")
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    BigInt     @map("student_id")
  student      Student    @relation(fields: [studentId], references: [id])
  fileUrl      String     @map("file_url")
  submittedAt  DateTime   @default(now()) @map("submitted_at")
  grade        Float? // Nilai (misal: 85.5)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([assignmentId, studentId]) // Mahasiswa hanya bisa submit 1x per tugas
  @@map("assignment_submissions")
}

// Model baru untuk Sesi Presensi
model AttendanceSession {
  id              BigInt        @id @default(autoincrement())
  classScheduleId BigInt        @map("class_schedule_id")
  classSchedule   ClassSchedule @relation(fields: [classScheduleId], references: [id], onDelete: Cascade)

  sessionDate DateTime @db.Date // Tanggal sesi ini diadakan
  startTime   DateTime // Waktu Dosen membuka presensi
  endTime     DateTime // Waktu Dosen menutup presensi
  status      String // "OPEN", "CLOSED"
  notes       String? // Misal: "Sesi ke-1: Pengenalan"

  // Relasi ke rekaman presensi
  records AttendanceRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("attendance_sessions")
}

// Model baru untuk Rekaman Presensi (Mahasiswa)
model AttendanceRecord {
  id                  BigInt            @id @default(autoincrement())
  attendanceSessionId BigInt            @map("attendance_session_id")
  attendanceSession   AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)

  studentId BigInt  @map("student_id")
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status     String // "HADIR", "IZIN", "SAKIT", "ALPA"
  attendedAt DateTime @default(now()) // Waktu mahasiswa melakukan presensi

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Mahasiswa hanya bisa absen 1x per sesi
  @@unique([attendanceSessionId, studentId])
  @@map("attendance_records")
}

// ===========================================
// BLOK 4: KEUANGAN (FINANCE)
// ===========================================

model Invoice {
  id             BigInt       @id @default(autoincrement())
  studentId      BigInt       @map("student_id")
  student        Student      @relation(fields: [studentId], references: [id])
  academicYearId BigInt       @map("academic_year_id")
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  
  amount         Float
  description    String       // e.g., "UKT Semester Ganjil 2024/2025"
  dueDate        DateTime     @map("due_date")
  status         String       // "PENDING", "PAID", "CANCELLED"
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  payments       Payment[]

  @@map("invoices")
}

model Payment {
  id             BigInt       @id @default(autoincrement())
  invoiceId      BigInt       @map("invoice_id")
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  
  amount         Float
  paymentDate    DateTime     @default(now()) @map("payment_date")
  paymentMethod  String       // "BANK_TRANSFER", "CASH"
  reference      String?      // Reference number or proof of payment URL
  status         String       // "PENDING", "VERIFIED", "REJECTED"
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("payments")
}

// ===========================================
// BLOK 5: TUGAS AKHIR & BIMBINGAN
// ===========================================

model Thesis {
  id          BigInt       @id @default(autoincrement())
  studentId   BigInt       @unique @map("student_id") // 1 Student = 1 Active Thesis
  student     Student      @relation(fields: [studentId], references: [id])
  
  title       String       @db.Text
  abstract    String?      @db.Text
  status      String       // "PROPOSED", "ACTIVE", "COMPLETED", "REJECTED"
  
  startDate   DateTime?    @map("start_date")
  endDate     DateTime?    @map("end_date")
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  supervisors    ThesisSupervisor[]
  counselingLogs CounselingLog[]
  defense        ThesisDefense?

  @@map("theses")
}

model ThesisSupervisor {
  id          BigInt       @id @default(autoincrement())
  thesisId    BigInt       @map("thesis_id")
  thesis      Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  lecturerId  BigInt       @map("lecturer_id")
  lecturer    Lecturer     @relation(fields: [lecturerId], references: [id])
  
  role        String       // "PEMBIMBING_1", "PEMBIMBING_2"
  status      String       @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([thesisId, lecturerId])
  @@map("thesis_supervisors")
}

model CounselingLog {
  id          BigInt       @id @default(autoincrement())
  thesisId    BigInt       @map("thesis_id")
  thesis      Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  lecturerId  BigInt       @map("lecturer_id")
  lecturer    Lecturer     @relation(fields: [lecturerId], references: [id])
  
  date        DateTime     @db.Date
  notes       String       @db.Text
  status      String       // "PENDING", "APPROVED", "REJECTED"
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("counseling_logs")
}

model ThesisDefense {
  id          BigInt       @id @default(autoincrement())
  thesisId    BigInt       @unique @map("thesis_id")
  thesis      Thesis       @relation(fields: [thesisId], references: [id], onDelete: Cascade)
  
  scheduledAt DateTime     @map("scheduled_at")
  facilityId  BigInt?      @map("facility_id")
  facility    Facility?    @relation(fields: [facilityId], references: [id])
  status      String       // "SCHEDULED", "PASSED", "FAILED"
  score       Float?
  notes       String?      @db.Text
  
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  examiners   ThesisExaminer[]

  @@map("thesis_defenses")
}

model ThesisExaminer {
  id              BigInt       @id @default(autoincrement())
  thesisDefenseId BigInt       @map("thesis_defense_id")
  thesisDefense   ThesisDefense @relation(fields: [thesisDefenseId], references: [id], onDelete: Cascade)
  lecturerId      BigInt       @map("lecturer_id")
  lecturer        Lecturer     @relation(fields: [lecturerId], references: [id])
  
  role            String       // "PENGUJI_1", "PENGUJI_2"
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@unique([thesisDefenseId, lecturerId])
  @@map("thesis_examiners")
}

// ===========================================
// BLOK 6: CUTI AKADEMIK
// ===========================================

model LeaveRequest {
  id              BigInt       @id @default(autoincrement())
  studentId       BigInt       @map("student_id")
  student         Student      @relation(fields: [studentId], references: [id])
  
  academicYearId  BigInt       @map("academic_year_id")
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])
  
  reason          String       @db.Text
  status          String       @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  documentUrl     String?      @map("document_url")
  adminNotes      String?      @map("admin_notes") @db.Text
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("leave_requests")
}

// ===========================================
// BLOK 7: EDOM (Evaluasi Dosen Oleh Mahasiswa)
// ===========================================

model EdomQuestion {
  id        BigInt   @id @default(autoincrement())
  question  String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  answers   EdomAnswer[]

  @@map("edom_questions")
}

model EdomSubmission {
  id        BigInt   @id @default(autoincrement())
  studentId BigInt   @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id])
  classId   BigInt   @map("class_id")
  class     Class    @relation(fields: [classId], references: [id])
  
  feedback  String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  answers   EdomAnswer[]

  @@unique([studentId, classId]) // One submission per student per class
  @@map("edom_submissions")
}

model EdomAnswer {
  id             BigInt         @id @default(autoincrement())
  submissionId   BigInt         @map("submission_id")
  submission     EdomSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId     BigInt         @map("question_id")
  question       EdomQuestion   @relation(fields: [questionId], references: [id])
  score          Int            // Usually 1-5

  @@unique([submissionId, questionId])
  @@map("edom_answers")
}

// ===========================================
// BLOK 8: KELULUSAN & ALUMNI
// ===========================================

model YudisiumRegistration {
  id           BigInt   @id @default(autoincrement())
  studentId    BigInt   @unique @map("student_id")
  student      Student  @relation(fields: [studentId], references: [id])
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  ipk          Float
  totalCredits Int      @map("total_credits")
  appliedAt    DateTime @default(now()) @map("applied_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("yudisium_registrations")
}

model WisudaEvent {
  id         BigInt               @id @default(autoincrement())
  batchName  String               // e.g. "Wisuda Angkatan 45"
  eventDate  DateTime             @map("event_date")
  isActive   Boolean              @default(true) @map("is_active")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  registrants WisudaRegistration[]

  @@map("wisuda_events")
}

model WisudaRegistration {
  id            BigInt      @id @default(autoincrement())
  studentId     BigInt      @unique @map("student_id")
  student       Student     @relation(fields: [studentId], references: [id])
  wisudaEventId BigInt      @map("wisuda_event_id")
  wisudaEvent   WisudaEvent @relation(fields: [wisudaEventId], references: [id])
  status        String      @default("REGISTERED") // REGISTERED, ATTENDED
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("wisuda_registrations")
}

model TracerStudy {
  id               BigInt   @id @default(autoincrement())
  studentId        BigInt   @unique @map("student_id")
  student          Student  @relation(fields: [studentId], references: [id])
  employed         Boolean  // Bekerja atau belum
  companyName      String?  @map("company_name")
  salaryRange      String?  @map("salary_range") // e.g. "3M-5M", "5M-10M"
  feedback         String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("tracer_studies")
}

// ===========================================
// BLOK 9: SYSTEM SETTINGS
// ===========================================
model SystemSetting {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique // e.g. "LIBRARY_DAILY_FINE"
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ===========================================
// BLOK 10: PERPUSTAKAAN (LIBRARY MANAGEMENT)
// ===========================================
model BookCategory {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  books     Book[]

  @@map("book_categories")
}

model Book {
  id              BigInt         @id @default(autoincrement())
  title           String
  author          String
  isbn            String?
  publisher       String?
  publishYear     Int?           @map("publish_year")
  copiesTotal     Int            @default(1) @map("copies_total")
  copiesAvailable Int            @default(1) @map("copies_available")
  categoryId      BigInt         @map("category_id")
  category        BookCategory   @relation(fields: [categoryId], references: [id])
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  borrowings      BookBorrowing[]

  @@map("books")
}

model BookBorrowing {
  id          BigInt    @id @default(autoincrement())
  bookId      BigInt    @map("book_id")
  book        Book      @relation(fields: [bookId], references: [id])
  studentId   BigInt    @map("student_id")
  student     Student   @relation(fields: [studentId], references: [id])
  borrowDate  DateTime  @default(now()) @map("borrow_date")
  dueDate     DateTime  @map("due_date")
  returnDate  DateTime? @map("return_date")
  status      String    @default("BORROWED") // BORROWED, RETURNED
  fineAmount  Int       @default(0) @map("fine_amount")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("book_borrowings")
}

// ===========================================
// BLOK 11: FASILITAS & PEMINJAMAN RUANG
// ===========================================
model Facility {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  type        String   // CLASSROOM, LABORATORY, MEETING_ROOM, SPORT
  capacity    Int
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  bookings    FacilityBooking[]
  classSchedules ClassSchedule[]
  thesisDefenses ThesisDefense[]

  @@map("facilities")
}

model FacilityBooking {
  id          BigInt   @id @default(autoincrement())
  facilityId  BigInt   @map("facility_id")
  facility    Facility @relation(fields: [facilityId], references: [id])
  userId      BigInt   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  purpose     String
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("facility_bookings")
}
